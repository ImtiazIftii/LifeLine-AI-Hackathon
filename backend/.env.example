# Render production environment template
NODE_ENV=production
PORT=4000
DATABASE_URL=postgresql://postgres.[project-ref]:password@aws-0-region.pooler.supabase.com:6543/postgres
DATABASE_SSL=true
REDIS_URL=
NEO4J_URI=neo4j+s://your-instance.databases.neo4j.io
NEO4J_USER=neo4j
NEO4J_PASSWORD=replace-with-aura-password
JWT_SECRET=replace-with-a-long-random-secret
CORS_ORIGINS=https://your-vercel-project.vercel.app
ALLOW_VERCEL_PREVIEWS=false
ALLOW_DEMO_ROLE_HEADER=false
ENABLE_DEMO_ACCOUNTS=false
ALLOW_PRIVILEGED_SELF_REGISTRATION=false
DOCS_ADMIN_EMAIL=admin@your-project.example
DOCS_ADMIN_PASSWORD=replace-with-a-strong-private-password
DOCS_SUPER_ADMIN_EMAIL=
DOCS_SUPER_ADMIN_PASSWORD=
LLM_PROVIDER=mock
